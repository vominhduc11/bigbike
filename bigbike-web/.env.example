# =============================================================
# bigbike-web — Next.js public site
# Copy to .env.local (gitignored). NEVER commit real values.
# =============================================================

# Backend API base URL (server-side, not exposed to browser)
BIGBIKE_API_BASE_URL=http://localhost:8080

# Backend API base URL (client-side, exposed via NEXT_PUBLIC_)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Secret used by backend/admin mutations to purge Next.js ISR tags.
# Must match WEB_REVALIDATE_SECRET in the backend/root environment.
REVALIDATE_SECRET=CHANGE_ME_RANDOM_SECRET

# Canonical site URL used for metadata / og:url / sitemap
BIGBIKE_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# TTL (seconds) for the in-process redirect lookup cache in proxy.ts.
# Cached entries expire after this many seconds; set to 0 to disable caching.
BIGBIKE_REDIRECT_CACHE_TTL_SECONDS=300

# Legacy media proxy — Next.js rewrites /wp-content/uploads/* to this base URL.
# Used as the CSP img-src origin at build time (browser-visible).
# Default: https://cdn.bigbike.vn/uploads (production CDN, server-side fetch).
# Dev override: point to local MinIO after running Phase 2E media copy.
# Example: BIGBIKE_LEGACY_UPLOADS_BASE=http://localhost:9000/bigbike-media/wp-uploads
BIGBIKE_LEGACY_UPLOADS_BASE=

# Server-side rewrite destination used by Next.js inside Docker. Must point to the
# internal Docker hostname (e.g. minio:9000) because localhost:9000 is unreachable
# from inside the container. Falls back to BIGBIKE_LEGACY_UPLOADS_BASE when unset,
# so local `next dev` works without this variable.
# Example: BIGBIKE_MEDIA_INTERNAL_URL=http://minio:9000/bigbike-media/wp-uploads
BIGBIKE_MEDIA_INTERNAL_URL=

# MinIO bucket root URL (no /wp-uploads suffix) used for the /media/* rewrite.
# Serves both new uploads (uploads/…) and migrated WP files (wp-uploads/…).
# Auto-derived from BIGBIKE_MEDIA_INTERNAL_URL when unset (strips /wp-uploads suffix).
# Example: BIGBIKE_MEDIA_BUCKET_URL=http://minio:9000/bigbike-media
BIGBIKE_MEDIA_BUCKET_URL=

# Google Tag Manager
# IMPORTANT: staging MUST use a separate GTM container (or leave this empty) to avoid
# polluting production GA4 data with test traffic.
# Production container: GTM-5BKZL3K
# Staging: set to a dedicated test container ID, or leave empty to disable GTM entirely.
NEXT_PUBLIC_GTM_ID=GTM-5BKZL3K

# --- One-off scripts (scripts/extract-wp-data/) ---
# Used by load-sliders-to-backend.ts and similar migration scripts.
# OPTIONAL: set BIGBIKE_ADMIN_TOKEN to skip the login step entirely.
# If unset, the script logs in with BIGBIKE_ADMIN_EMAIL + BIGBIKE_ADMIN_PASSWORD
# to obtain a token automatically.
BIGBIKE_ADMIN_TOKEN=
BIGBIKE_ADMIN_EMAIL=
BIGBIKE_ADMIN_PASSWORD=
