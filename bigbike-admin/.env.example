# =============================================================
# bigbike-admin — Vite + React admin panel
# Copy to .env.local (gitignored). NEVER commit real values.
# =============================================================

# Backend API base URL
VITE_ADMIN_API_BASE=http://localhost:8080/api/v1

# Set to "true" to use in-memory mock data instead of real API
VITE_USE_ADMIN_MOCK=true

# Default role assumed in dev/mock mode
VITE_ADMIN_ROLE=ADMIN
