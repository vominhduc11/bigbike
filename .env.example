# BigBike backend database variables
BIGBIKE_DB_URL=jdbc:postgresql://localhost:5432/bigbike
BIGBIKE_DB_USERNAME=bigbike
BIGBIKE_DB_PASSWORD=bigbike

# Optional profiles:
# - dev: enables Flyway dev/test seed migrations
# - mock: disables datasource/JPA/Flyway and uses in-memory repositories
SPRING_PROFILES_ACTIVE=dev
