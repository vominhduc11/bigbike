# =============================================================
# BigBike dev infra — root .env.example
# Copy to .env and fill real values. NEVER commit .env.
# =============================================================

# --- PostgreSQL ---
POSTGRES_DB=bigbike
POSTGRES_USER=bigbike
POSTGRES_PASSWORD=bigbike_dev_only

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- MinIO (S3-compatible object storage) ---
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=minio_dev_only
MINIO_BUCKET=bigbike-media
MINIO_ENDPOINT=http://localhost:9000

# --- Spring Boot (mirrors bigbike-backend/.env.example) ---
SPRING_PROFILES_ACTIVE=dev
BIGBIKE_DB_URL=jdbc:postgresql://localhost:5432/bigbike
BIGBIKE_DB_USERNAME=bigbike
BIGBIKE_DB_PASSWORD=bigbike_dev_only
