# =============================================================
# BigBike dev infra — root .env.example
# Copy to .env and fill real values. NEVER commit .env.
# =============================================================

# --- PostgreSQL ---
POSTGRES_DB=bigbike
POSTGRES_USER=bigbike
POSTGRES_PASSWORD=bigbike_dev_only

# --- MinIO (S3-compatible object storage) ---
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=minio_dev_only
MINIO_BUCKET=bigbike-media

# --- Spring Boot ---
# Use "dev" for local development (skips strict JWT secret validation, loads seed data).
# Use "prod" for staging/production (requires BIGBIKE_JWT_SECRET to be non-default, >= 32 chars).
# NOTE: BIGBIKE_DB_*, MINIO_ENDPOINT for backend are wired by docker-compose.yaml
# using POSTGRES_* + Docker network hostnames (postgres/minio). For local non-Docker
# dev (mvn spring-boot:run), see bigbike-backend/.env.local.
SPRING_PROFILES_ACTIVE=dev

# REQUIRED for SPRING_PROFILES_ACTIVE=prod — must be >= 32 chars, not the default value.
# Generate a secure value: openssl rand -base64 48
BIGBIKE_JWT_SECRET=CHANGE_ME_IN_PRODUCTION_USE_RANDOM_32_CHARS

# CORS — comma-separated exact origins, no wildcards, no trailing slashes
BIGBIKE_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4000

# Reverse-proxy IPs trusted to set X-Forwarded-For (per-IP rate limiting). Comma-separated;
# each entry is an exact IP or a CIDR range. Default = localhost only.
# When the backend runs behind nginx / inside Docker, set this to the proxy IP or the
# Docker bridge subnet (e.g. 172.16.0.0/12) — otherwise per-IP rate limiting collapses to
# a single shared bucket. See docs/engineering/DEPLOYMENT_GUIDE.md.
BIGBIKE_TRUSTED_PROXIES=127.0.0.1,::1

# Frontend public URLs — baked into the client bundle at build time (NEXT_PUBLIC_ prefix).
# For production set these to the real public URLs before running docker compose build.
# e.g. NEXT_PUBLIC_API_BASE_URL=https://api.bigbike.vn
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-side canonical site URL (used by Next.js for metadata/og:url/sitemap).
# Override in production: BIGBIKE_SITE_URL=https://bigbike.vn
BIGBIKE_SITE_URL=http://localhost:3000

# --- On-demand revalidation (backend → Next.js cache purge) ---
# Generate: openssl rand -base64 32
WEB_REVALIDATE_SECRET=CHANGE_ME_RANDOM_SECRET
# URL the backend calls to purge Next.js cache (must include /api/revalidate path).
# Example: http://bigbike-web:3000/api/revalidate  (Docker internal hostname)
WEB_REVALIDATE_URL=http://localhost:3000/api/revalidate

# --- Transactional email (SMTP) ---
# Leave BIGBIKE_MAIL_HOST empty to disable mail entirely (safe for local dev — backend logs "Mail not configured — skipped").
# For Gmail: host=smtp.gmail.com, port=587, password = App Password (NOT account password).
# Generate App Password at: https://myaccount.google.com/apppasswords
BIGBIKE_MAIL_HOST=
BIGBIKE_MAIL_PORT=587
BIGBIKE_MAIL_USERNAME=
BIGBIKE_MAIL_PASSWORD=
BIGBIKE_MAIL_SMTP_AUTH=true
BIGBIKE_MAIL_STARTTLS=true
BIGBIKE_MAIL_FROM=no-reply@bigbike.vn
BIGBIKE_MAIL_ADMIN=info@bigbike.vn
BIGBIKE_MAIL_VERIFY_BASE_URL=https://bigbike.vn/xac-nhan-email
BIGBIKE_MAIL_RESET_BASE_URL=https://bigbike.vn/quen-mat-khau

# --- Backend public URLs (used in transactional email templates + admin links) ---
# Override in production, e.g. BIGBIKE_SITE_BASE_URL=https://bigbike.vn
BIGBIKE_SITE_BASE_URL=https://bigbike.vn
BIGBIKE_ADMIN_BASE_URL=https://admin.bigbike.vn

# Media URL allowlist anchor — admin write paths reject media URLs not under this base.
# Leave empty to derive from MINIO_ENDPOINT/MINIO_BUCKET (good for local dev).
# Production example: BIGBIKE_MEDIA_PUBLIC_BASE_URL=https://cdn.bigbike.vn/uploads
BIGBIKE_MEDIA_PUBLIC_BASE_URL=

# --- Frontend (bigbike-web) runtime ---
# In-process redirect lookup cache TTL in seconds (0 = disabled).
BIGBIKE_REDIRECT_CACHE_TTL_SECONDS=300
# Set to "false" to disable middleware hit-tracking (fire-and-forget POST to backend).
REDIRECT_HIT_TRACKING=true

# Google Tag Manager. Production: GTM-5BKZL3K. Staging: leave empty or use a dedicated test container.
NEXT_PUBLIC_GTM_ID=

# Sentry — set DSN to enable error reporting. AUTH_TOKEN/ORG/PROJECT are needed only at build time
# for source-map upload (CI/build server). Leave all empty in dev.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
