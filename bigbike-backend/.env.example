# =============================================================
# bigbike-backend — Spring Boot 4 / Java 17
# Copy to .env (gitignored). NEVER commit real values.
# =============================================================

# Spring profiles: "dev" enables Flyway dev seed; "mock" disables DB entirely
SPRING_PROFILES_ACTIVE=dev

# --- PostgreSQL ---
BIGBIKE_DB_URL=jdbc:postgresql://localhost:5432/bigbike
BIGBIKE_DB_USERNAME=bigbike
BIGBIKE_DB_PASSWORD=bigbike_dev_only

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4000

# --- JWT ---
BIGBIKE_JWT_SECRET=dev-change-me-in-production-needs-32chars!!

# --- Object storage / MinIO ---
MINIO_ENDPOINT=http://localhost:9000
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=minio_dev_only
MINIO_BUCKET=bigbike-media

# --- Transactional email (optional) ---
# Leave BIGBIKE_MAIL_HOST empty to disable all email sending (safe for local dev).
# For staging/production set all values below. Use an App Password for Gmail.
# BIGBIKE_MAIL_HOST=smtp.gmail.com
# BIGBIKE_MAIL_PORT=587
# BIGBIKE_MAIL_USERNAME=noreply@bigbike.vn
# BIGBIKE_MAIL_PASSWORD=your_app_password_here
# BIGBIKE_MAIL_FROM=no-reply@bigbike.vn
# BIGBIKE_MAIL_ADMIN=info@bigbike.vn          # Nhận thông báo đơn hàng mới + form liên hệ
# BIGBIKE_MAIL_VERIFY_BASE_URL=https://bigbike.vn/xac-nhan-email
# BIGBIKE_MAIL_RESET_BASE_URL=https://bigbike.vn/quen-mat-khau
# BIGBIKE_SITE_BASE_URL=https://bigbike.vn
# BIGBIKE_ADMIN_BASE_URL=https://admin.bigbike.vn

# --- WordPress migration (Phase 2D) ---
# All five guards below MUST be set to trigger a real DB import. Leave these
# commented out in normal operation — the runner is a complete no-op by default.
#
# HOW TO RUN (local / staging only):
#   1. Place the WordPress SQL dump at the path below.
#   2. Start the application with the properties below uncommented.
#   3. Verify the import report in the application logs.
#   4. Re-run to confirm idempotency (inserted=0, updated=same count).
#   WARNING: NEVER point at a production DB. The runner rejects URL patterns
#   containing: bigbike.vn, prod, production, rds.amazonaws, cloudsql, etc.
#
# BIGBIKE_MIGRATION_WORDPRESS_ENABLED=true
# BIGBIKE_MIGRATION_WORDPRESS_DRY_RUN=false
# BIGBIKE_MIGRATION_WORDPRESS_MODE=import
# BIGBIKE_MIGRATION_WORDPRESS_CONFIRM_EXECUTE=true
# BIGBIKE_MIGRATION_WORDPRESS_ENVIRONMENT=local
# BIGBIKE_MIGRATION_WORDPRESS_DUMP_PATH=/absolute/path/to/bigbike_wordpress.sql
# BIGBIKE_MIGRATION_WORDPRESS_UPLOADS_PATH=/absolute/path/to/wp-content/uploads
# BIGBIKE_MIGRATION_WORDPRESS_TABLE_PREFIX=kd_
# BIGBIKE_MIGRATION_WORDPRESS_BATCH_SIZE=500
# BIGBIKE_MIGRATION_WORDPRESS_DOMAINS=
