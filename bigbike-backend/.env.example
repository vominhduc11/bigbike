# =============================================================
# bigbike-backend — Spring Boot 4 / Java 17
# Copy to .env (gitignored). NEVER commit real values.
# =============================================================

# Spring profiles: "dev" enables Flyway dev seed; "mock" disables DB entirely
SPRING_PROFILES_ACTIVE=dev

# --- PostgreSQL ---
BIGBIKE_DB_URL=jdbc:postgresql://localhost:5432/bigbike
BIGBIKE_DB_USERNAME=bigbike
BIGBIKE_DB_PASSWORD=bigbike_dev_only

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4173

# --- JWT (Phase 1 — placeholder only, NOT used in Phase 0) ---
# JWT_SECRET=change_me_min_32_chars_random_string
# JWT_ACCESS_TTL_SECONDS=900
# JWT_REFRESH_TTL_SECONDS=604800

# --- Object storage / MinIO (Phase 1) ---
# STORAGE_ENDPOINT=http://localhost:9000
# STORAGE_BUCKET=bigbike-media
# STORAGE_ACCESS_KEY=minio_admin
# STORAGE_SECRET_KEY=minio_dev_only

# --- SMTP (Phase 1) ---
# SMTP_HOST=localhost
# SMTP_PORT=1025
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=no-reply@bigbike.vn
